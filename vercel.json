{
  "version": 2,
  "alias": ["nagendra-portfolios.vercel.app"],
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client/client",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/client/server/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.ts"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.ts"
    }
  ]
}